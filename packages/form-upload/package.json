{
  "name": "@availity/form-upload",
  "version": "3.0.0",
  "description": "Availity upload component for uploading files, compatible with @availity/form",
  "keywords": [
    "react",
    "availity",
    "upload"
  ],
  "homepage": "https://availity.github.io/availity-react/form/upload/index",
  "bugs": {
    "url": "https://github.com/Availity/availity-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Availity/availity-react.git",
    "directory": "packages/form-upload"
  },
  "license": "MIT",
  "type": "module",
  "author": "Tyson Warner <tyson.warner@availity.com>",
  "scripts": {
    "build": "tsup --clean",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "publish": "yarn npm publish --tolerate-republish --access public",
    "publish:canary": "yarn npm publish --access public --tag canary"
  },
  "dependencies": {
    "@availity/icon": "workspace:*",
    "@availity/progress": "workspace:*",
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@availity/api-axios": "^13.0.2",
    "@availity/form": "workspace:*",
    "@availity/upload-core": "^9.0.2",
    "formik": "^2.4.9",
    "nock": "^13.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^11.7.1",
    "reactstrap": "^8.10.1",
    "tsup": "^8.5.1",
    "xhr-mock": "^2.5.1"
  },
  "peerDependencies": {
    "@availity/api-axios": "^12.0.0 || ^13.0.0",
    "@availity/form": "workspace:*",
    "@availity/upload-core": "^8.1.1",
    "formik": "^2.4.6",
    "react": "^18.0.0",
    "react-dropzone": "^11.7.1",
    "reactstrap": "^8.10.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "source": "./src/index.js",
      "import": {
        "types": "./src/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.scss": "./styles.scss"
  }
}
