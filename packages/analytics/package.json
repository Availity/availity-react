{
  "name": "@availity/analytics",
  "version": "2.0.0",
  "description": "Track click and page view events for the user.",
  "keywords": [
    "react",
    "availity",
    "analytics"
  ],
  "homepage": "https://availity.github.io/availity-react/components/analytics/index",
  "bugs": {
    "url": "https://github.com/Availity/availity-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Availity/availity-react.git",
    "directory": "packages/analytics"
  },
  "license": "MIT",
  "type": "module",
  "author": "Kyle Gray <kyle.gray@gmail.com>",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --dts",
    "dev": "tsup src/index.ts --format esm --watch --dts",
    "clean": "rm -rf dist",
    "publish": "yarn npm publish --tolerate-republish --access public",
    "publish:canary": "yarn npm publish --access public --tag canary"
  },
  "dependencies": {
    "@availity/analytics-core": "^7.0.2",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
