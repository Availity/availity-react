    "react-with-direction": "^1.4.0"
  },
  "devDependencies": {
    "@types/react-dates": "^21.8.6",
    "availity-reactstrap-validation": "^2.7.1",
    "date-fns": "^2.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactstrap": "^8.10.1",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "availity-reactstrap-validation": "^2.7.1",
    "date-fns": "^2.30.0",
    "react": "^18.0.0",
    "reactstrap": "^8.10.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
