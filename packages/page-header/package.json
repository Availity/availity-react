{
  "name": "@availity/page-header",
  "version": "14.0.26",
  "description": "The standard page header for Availity Portal Applications",
  "keywords": [
    "react",
    "availity",
    "page",
    "header"
  ],
  "homepage": "https://availity.github.io/availity-react/components/page-header",
  "bugs": {
    "url": "https://github.com/Availity/availity-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Availity/availity-react.git",
    "directory": "packages/page-header"
  },
  "license": "MIT",
  "type": "module",
  "author": "Evan Sharp <evan.sharp@availity.com>",
  "scripts": {
    "build": "tsup --clean",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "publish": "yarn npm publish --tolerate-republish --access public",
    "publish:canary": "yarn npm publish --access public --tag canary"
  },
  "dependencies": {
    "@availity/app-icon": "workspace:*",
    "@availity/breadcrumbs": "workspace:*",
    "@availity/feedback": "workspace:*",
    "@availity/payer-logo": "workspace:*",
    "classnames": "^2.5.1",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@availity/api-axios": "^13.0.2",
    "@availity/spaces": "workspace:*",
    "@availity/training-link": "workspace:*",
    "axios": "^1.17.0",
    "formik": "^2.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "yup": "^0.32.11"
  },
  "peerDependencies": {
    "@availity/api-axios": "^12.0.0 || ^13.0.0",
    "@availity/spaces": "workspace:*",
    "axios": "^1.13.2",
    "formik": "^2.4.6",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "yup": "^0.32.11"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "source": "./index.js",
      "import": {
        "types": "./index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.scss": "./styles.scss"
  }
