    "axios": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactstrap": "^8.10.1",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "@availity/api-axios": "^12.0.0 || ^13.0.0",
