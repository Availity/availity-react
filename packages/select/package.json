{
  "name": "@availity/select",
  "version": "5.0.0",
  "description": "Wrapper for react-select to work with formik",
  "keywords": [
    "availity",
    "formik",
    "select"
  ],
  "homepage": "https://availity.github.io/availity-react/form/select/index",
  "bugs": {
    "url": "https://github.com/Availity/availity-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Availity/availity-react.git",
    "directory": "packages/select"
  },
  "license": "MIT",
  "type": "module",
  "author": "Evan Sharp <evan.sharp@availity.com>",
  "scripts": {
    "build": "tsup src/index.js --format esm --clean --dts",
    "dev": "tsup src/index.js --format esm --watch --dts",
    "clean": "rm -rf dist",
    "clean:nm": "rm -rf node_modules",
    "publish": "yarn npm publish --tolerate-republish --access public",
    "publish:canary": "yarn npm publish --access public --tag canary"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "lodash": "^4.18.1",
    "prop-types": "^15.8.1",
    "qs": "^6.15.2",
    "react-select": "^5.10.2",
    "react-select-async-paginate": "^0.6.2"
  },
  "devDependencies": {
    "@availity/api-axios": "^13.2.0",
    "@availity/form": "workspace:*",
    "axios": "^1.17.0",
    "formik": "^2.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactstrap": "^8.10.1",
    "tsup": "^8.5.1",
    "yup": "^0.32.11"
  },
  "peerDependencies": {
    "@availity/api-axios": "^12.0.0 || ^13.0.0",
    "@availity/form": "workspace:*",
    "axios": "^1.13.2",
    "formik": "^2.4.6",
    "react": "^18.0.0",
    "reactstrap": "^8.10.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "source": "./src/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  }
}
