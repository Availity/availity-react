{
  "name": "@availity/upload",
  "version": "5.0.0",
  "author": "Evan Sharp <evan.sharp@availity.com>",
  "description": "Availity upload component for uploading files",
  "keywords": [
    "react",
    "availity",
    "upload"
  ],
  "homepage": "https://github.com/Availity/availity-react/tree/master/packages/upload#readme",
  "bugs": {
    "url": "https://github.com/Availity/availity-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Availity/availity-react.git",
    "directory": "packages/upload"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup --clean",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "publish": "yarn npm publish --tolerate-republish --access public",
    "publish:canary": "yarn npm publish --access public --tag canary"
  },
  "dependencies": {
    "@availity/progress": "workspace:*",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@availity/upload-core": "^9.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^11.7.1",
    "reactstrap": "^8.10.1",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "@availity/upload-core": "^8.1.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-dropzone": "^11.7.1",
    "reactstrap": "^8.10.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "source": "./index.js",
      "import": {
        "types": "./index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.scss": "./styles.scss"
  }
}
