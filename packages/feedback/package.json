{
  "name": "@availity/feedback",
  "version": "10.0.0",
  "description": "Availity feedback with smiley faces react component.",
  "keywords": [
    "react",
    "availity",
    "feedback"
  ],
  "homepage": "https://availity.github.io/availity-react/components/feedback/index",
  "bugs": {
    "url": "https://github.com/Availity/availity-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Availity/availity-react.git",
    "directory": "packages/feedback"
  },
  "license": "MIT",
  "type": "module",
  "author": "Evan Sharp <evan.sharp@availity.com>",
  "scripts": {
    "build": "tsup index.js --format esm --clean --dts",
    "dev": "tsup index.js --format esm --watch --dts",
    "clean": "rm -rf dist",
    "publish": "yarn npm publish --tolerate-republish --access public",
    "publish:canary": "yarn npm publish --access public --tag canary"
  },
  "dependencies": {
    "@availity/block-ui": "workspace:^",
    "@availity/form": "workspace:*",
    "@availity/hooks": "workspace:*",
    "@availity/icon": "workspace:*",
    "@availity/native-form": "^8.0.2",
    "@availity/select": "workspace:*",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@availity/api-axios": "^13.0.2",
    "@availity/yup": "^7.1.0",
    "axios": "^1.17.0",
    "formik": "^2.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactstrap": "^8.10.1",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "@availity/api-axios": "^12.0.0 || ^13.0.0",
    "@availity/yup": "^7.0.0",
    "axios": "^1.13.2",
    "formik": "^2.4.6",
    "react": "^18.0.0",
    "reactstrap": "^8.10.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "source": "./index.js",
      "import": {
        "types": "./index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
