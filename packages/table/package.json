{
  "name": "@availity/table",
  "version": "0.6.22",
  "description": "A generic table wrapper for react-table",
  "keywords": [
    "react",
    "availity"
  ],
  "bugs": {
    "url": "https://github.com/Availity/availity-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Availity/availity-react.git",
    "directory": "packages/table"
  },
  "license": "MIT",
  "type": "module",
  "author": "Ashlee Zeigler <ashlee.zeigler@availity.com>",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --dts",
    "dev": "tsup src/index.ts --format esm --watch --dts",
    "clean": "rm -rf dist",
    "clean:nm": "rm -rf node_modules",
    "publish": "yarn npm publish --tolerate-republish --access public",
    "publish:canary": "yarn npm publish --access public --tag canary"
  },
  "dependencies": {
    "@availity/hooks": "workspace:*",
    "@availity/icon": "workspace:*",
    "@types/react-table": "^7.7.20",
    "classnames": "^2.5.1",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "react-table": "^7.8.0"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactstrap": "^8.10.1",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "availity-uikit": ">=4.7.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "reactstrap": "^8.10.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.scss": "./styles.scss"
  }
}
