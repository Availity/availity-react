{
  "name": "@availity/avatar",
  "version": "3.0.1",
  "description": "Availity User avatar component",
  "keywords": [
    "react",
    "availity",
    "avatar"
  ],
  "homepage": "https://availity.github.io/availity-react/components/avatar",
  "bugs": {
    "url": "https://github.com/Availity/availity-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Availity/availity-react.git",
    "directory": "packages/avatar"
  },
  "license": "MIT",
  "type": "module",
  "author": "Tyson Warner <tyson.warner@availity.com>",
  "scripts": {
    "publish": "yarn npm publish --tolerate-republish --access public",
    "publish:canary": "yarn npm publish --access public --tag canary",
    "build": "tsup index.js --format esm --clean --dts",
    "dev": "tsup index.js --format esm --watch --dts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@availity/hooks": "workspace:*",
    "lodash": "^4.18.1",
    "prop-types": "^15.8.1",
    "react-image": "^4.1.0",
    "react-loading-skeleton": "^2.2.0"
  },
  "devDependencies": {
    "@availity/api-axios": "^13.2.0",
    "axios": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "@availity/api-axios": "^12.0.0 || ^13.0.0",
    "axios": "^1.13.2",
    "react": "^18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "source": "./index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  }
}
