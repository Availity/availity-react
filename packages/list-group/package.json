{
  "name": "@availity/list-group",
  "version": "1.4.10",
  "description": "List Group with some Availity flair",
  "keywords": [
    "react",
    "availity",
    "list"
  ],
  "homepage": "https://availity.github.io/availity-react/components/list-group",
  "bugs": {
    "url": "https://github.com/Availity/availity-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Availity/availity-react.git",
    "directory": "packages/list-group"
  },
  "license": "MIT",
  "type": "module",
  "author": "Evan Sharp <evan.sharp@availity.com>",
  "scripts": {
    "build": "tsup index.js --format esm --clean --dts",
    "dev": "tsup index.js --format esm --watch --dts",
    "clean": "rm -rf dist",
    "publish": "yarn npm publish --tolerate-republish --access public",
    "publish:canary": "yarn npm publish --access public --tag canary"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactstrap": "^8.10.1",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "reactstrap": "^8.10.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "source": "./index.js",
      "import": {
        "types": "./index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
