{
  "name": "@availity/form",
  "version": "2.0.0",
  "description": "Form Wrapper around formik using reactstrap components",
  "keywords": [
    "react",
    "availity",
    "form",
    "formik"
  ],
  "homepage": "https://availity.github.io/availity-react/form/index",
  "bugs": {
    "url": "https://github.com/Availity/availity-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Availity/availity-react.git",
    "directory": "packages/form"
  },
  "license": "MIT",
  "type": "module",
  "author": "Kyle Gray <kyle.gray@availity.com>",
  "scripts": {
    "build": "tsup src/index.js --format esm --clean --dts",
    "dev": "tsup src/index.js --format esm --watch --dts",
    "clean": "rm -rf dist",
    "clean:nm": "rm -rf node_modules",
    "publish": "yarn npm publish --tolerate-republish --access public",
    "publish:canary": "yarn npm publish --access public --tag canary"
  },
  "dependencies": {
    "@availity/icon": "workspace:*",
    "@availity/message-core": "^9.0.2",
    "classnames": "^2.5.1",
    "prop-types": "^15.8.1",
    "react-currency-input-field": "^3.10.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "formik": "^2.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactstrap": "^8.10.1",
    "tsup": "^8.5.1",
    "yup": "^0.32.11"
  },
  "peerDependencies": {
    "formik": "^2.4.6",
    "react": "^18.0.0",
    "reactstrap": "^8.10.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "source": "./src/index.js",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
